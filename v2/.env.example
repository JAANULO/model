# Wspolna konfiguracja lokalnie/serwer (bez zmian kodu)
APP_ENV=local

# DB_BACKEND: auto | sqlite | postgres
DB_BACKEND=auto
DATABASE_URL=
DB_CONNECT_TIMEOUT=5
DB_SSLMODE=require

# HTTP / Flask
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=1

# Bezpieczenstwo / logi
ADMIN_TOKEN=dev-token-zmien-mnie
LOG_LEVEL=INFO

